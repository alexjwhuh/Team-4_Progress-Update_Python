   "source": [
    "# Clean the dataframe for machine learning\n",
    "df_model = tourism_climate.copy()\n",
    "df_model = df_model.dropna(subset=['Tourist'])\n",
    "df_model = df_model.drop(columns=['Tourist (Japan)', 'Prefecture Visit Rate'])\n",
    "df_model = df_model.drop(columns=['Max Temp (°C)', 'Min Temp (°C)'])\n",
    "# Keep only the selected features plus the target\n",
    "df_model = df_model[[\n",
    "    'Year',\n",
    "    'Month',\n",
    "    'Prefecture',\n",
    "    'Ave Temp (°C)',\n",
    "    'Precipitation (mm)',\n",
    "    'Humidity (%)',\n",
    "    'Windspeed (m/s)',\n",
    "    'Rainfall',\n",
    "    'Tourist'\n",
    "]]\n",
    "# Convert numeric feature columns to numeric and coerce invalid values to NaN\n",
    "numeric_cols = ['Year', 'Ave Temp (°C)', 'Precipitation (mm)', 'Humidity (%)', 'Windspeed (m/s)']\n",
    "for col in numeric_cols:\n",
    "    df_model[col] = pd.to_numeric(df_model[col], errors='coerce')\n",
    "\n",
    "# Impute remaining numeric weather features with the median\n",
    "impute_cols = ['Ave Temp (°C)', 'Precipitation (mm)', 'Humidity (%)', 'Windspeed (m/s)']\n",
    "median_values = df_model[impute_cols].median()\n",
    "df_model[impute_cols] = df_model[impute_cols].fillna(median_values)\n",
    "\n",
    "print('After numeric conversion and imputation:')\n",
    "print(df_model[numeric_cols].isna().sum())\n",
    "print(\"Shape:\", df_model.shape)\n",
    "print(\"Columns:\", df_model.columns.tolist())"
