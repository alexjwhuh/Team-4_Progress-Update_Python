    "print('Unique Month values before conversion:')\n",
    "print(sorted(df_model['Month'].dropna().unique()))\n",
    "\n",
    "\n",
    "def convert_month(value):\n",
    "    if pd.isna(value):\n",
    "        return value\n",
    "    if isinstance(value, str):\n",
    "        normalized = value.strip().title()[:3]\n",
    "        return month_map.get(normalized, value)\n",
    "    return value\n",
    "\n",
    "# Convert only string month abbreviations to numeric values\n",
    "if df_model['Month'].dtype == object or df_model['Month'].dtype == 'string':\n",
    "    df_model['Month'] = df_model['Month'].apply(convert_month)\n",
